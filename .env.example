# ==========================================
# INTEGRATION MODE
# ==========================================
# Khuyen dung neu dang dung Sapo: sapo_webhook
# Khuyen dung neu dang dung Nhanh.vn: nhanh_webhook
# Chi dung shopee_api neu ban da co Shopee Open API + token.
# Dung sapo_go_scrape neu muon cao tu dong tu Sapo Go: sapo_go_scrape
INTEGRATION_MODE=sapo_webhook
SHOP_NAME=Ten shop cua ban
# true: day tung don vao Lark Base. false: chi luu local de tinh doanh thu/top san pham.
SYNC_ORDER_DETAILS_TO_LARK=false

# ==========================================
# SAPO WEBHOOK / API / SCRAPER
# ==========================================
SAPO_STORE=ten-shop-cua-ban
SAPO_STORE_ALIAS=luxi-decor.mysapogo.com
SAPO_GO_USERNAME=tai_khoan_sapo_go_cua_ban
SAPO_GO_PASSWORD=mat_khau_sapo_go_cua_ban
SAPO_API_KEY=
SAPO_API_SECRET=
SAPO_ACCESS_TOKEN=
SAPO_WEBHOOK_VERIFY_TOKEN=dat_mot_chuoi_bi_mat_o_day

# ==========================================
# NHANH.VN WEBHOOK
# ==========================================
NHANH_WEBHOOK_VERIFY_TOKEN=dat_mot_chuoi_bi_mat_o_day

# ==========================================
# SHOPEE API CREDENTIALS (chi can khi INTEGRATION_MODE=shopee_api)
# ==========================================
SHOPEE_PARTNER_ID=
SHOPEE_API_SECRET=
SHOPEE_SHOP_ID=
SHOPEE_BASE_URL=https://partner.shopeemobile.com
# URL nay phai trung voi redirect/callback URL da khai bao trong Shopee Open Platform app.
SHOPEE_REDIRECT_URL=https://your-domain.com/api/shopee/oauth/callback
# Tuy chon: neu ban da co token thi dan vao day. He thong se uu tien token trong SQLite neu da setup OAuth thanh cong.
SHOPEE_ACCESS_TOKEN=
SHOPEE_REFRESH_TOKEN=
SHOPEE_TOKEN_EXPIRE_AT=0

# ==========================================
# LARK (FEISHU) CREDENTIALS
# ==========================================
LARK_APP_ID=your_lark_app_id_here
LARK_APP_SECRET=your_lark_app_secret_here
LARK_CHAT_ID=your_group_chat_id_here
# External group dung Custom Bot webhook thay cho LARK_CHAT_ID.
LARK_WEBHOOK_URL=

# Lark Base/Bitable de luu don hang tu webhook.
# Tao Base voi cac cot trung ten ben duoi, hoac doi mapping field cho khop.
LARK_BASE_APP_TOKEN=
LARK_BASE_TABLE_ID=
LARK_ORDER_UNIQUE_FIELD=Ma don
LARK_FIELD_SOURCE=Nguon
LARK_FIELD_PLATFORM=San
LARK_FIELD_STATUS=Trang thai
LARK_FIELD_REVENUE=Doanh thu
LARK_FIELD_DISCOUNT=Giam gia
LARK_FIELD_SHIPPING=Phi van chuyen
LARK_FIELD_CUSTOMER=Khach hang
LARK_FIELD_PRODUCTS=San pham
LARK_FIELD_IMAGES=Anh thiet ke
LARK_FIELD_CREATED_AT=Ngay tao
LARK_FIELD_UPDATED_AT=Cap nhat luc

# ==========================================
# OPENAI (TÙY CHỌN - CHO PHÂN TÍCH AI)
# ==========================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ENABLED=false

# ==========================================
# SERVER CONFIG
# ==========================================
PORT=3000
NODE_ENV=production

# ==========================================
# SCHEDULE CONFIG (cron syntax)
# ==========================================
# Báo cáo lúc 7:00 sáng hàng ngày
REPORT_CRON=0 7 * * *
# Refresh token mỗi 3 tiếng
TOKEN_REFRESH_CRON=0 */3 * * *

# ==========================================
# TIMEZONE
# ==========================================
TZ=Asia/Ho_Chi_Minh
