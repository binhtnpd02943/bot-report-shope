# ==========================================
# INTEGRATION MODE
# ==========================================
# sapo_api: ket noi truc tiep Sapo API de chu dong lay don hang (Khuyen dung)
# sapo_webhook: dung Sapo webhook lam cau noi Shopee -> Lark
# shopee_api: dung Shopee Open API truc tiep
# nhanh_webhook: dung Nhanh.vn lam cau noi Shopee -> Lark
INTEGRATION_MODE=sapo_go_scrape
SHOP_NAME=LUXI DECOR
# true: day tung don vao Lark Base. false: chi luu local de tinh doanh thu/top san pham.
SYNC_ORDER_DETAILS_TO_LARK=false

# ==========================================
# SAPO API / WEBHOOK CONFIG
# ==========================================
SAPO_STORE=
SAPO_STORE_ALIAS=
SAPO_GO_USERNAME=
SAPO_GO_PASSWORD=
SAPO_ACCESS_TOKEN=
SAPO_API_KEY=
SAPO_API_SECRET=
SAPO_WEBHOOK_VERIFY_TOKEN=
EXCLUDED_SHOPS=


# ==========================================
# LARK (FEISHU) CREDENTIALS
# ==========================================
LARK_APP_ID=
LARK_APP_SECRET=
LARK_CHAT_ID=

# Lark Base/Bitable de luu don hang.
LARK_BASE_APP_TOKEN=
LARK_BASE_TABLE_ID=
LARK_ORDER_UNIQUE_FIELD=Ma don
LARK_FIELD_SOURCE=Nguon
LARK_FIELD_PLATFORM=San
LARK_FIELD_STATUS=Trang thai
LARK_FIELD_REVENUE=Doanh thu
LARK_FIELD_DISCOUNT=Giam gia
LARK_FIELD_SHIPPING=Phi van chuyen
LARK_FIELD_CUSTOMER=Khach hang
LARK_FIELD_PRODUCTS=San pham
LARK_FIELD_IMAGES=Anh thiet ke
LARK_FIELD_CREATED_AT=Ngay tao
LARK_FIELD_UPDATED_AT=Cap nhat luc

# ==========================================
# SERVER CONFIG
# ==========================================
PORT=3000
NODE_ENV=production

# ==========================================
# SCHEDULE CONFIG (cron syntax)
# ==========================================
# Báo cáo lúc 7:00 sáng hàng ngày
REPORT_CRON=0 7 * * *

# ==========================================
# TIMEZONE
# ==========================================
TZ=Asia/Ho_Chi_Minh
