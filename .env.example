# ==========================================
# INTEGRATION MODE
# ==========================================
# sapo_go_scrape : Cào trực tiếp từ Dashboard Sapo Go (Đang dùng - Khuyến dùng)
# sapo_api       : Kết nối Sapo API thuần
# shopee_api     : Dùng Shopee Open API trực tiếp
# nhanh_webhook  : Dùng Nhanh.vn webhook
INTEGRATION_MODE=sapo_go_scrape
SHOP_NAME=LUXI DECOR

# true: đẩy từng đơn hàng vào Lark Base. false: chỉ lưu local để tính doanh thu.
SYNC_ORDER_DETAILS_TO_LARK=false

# ==========================================
# SAPO GO SCRAPER CONFIG (INTEGRATION_MODE=sapo_go_scrape)
# ==========================================
SAPO_STORE_ALIAS=your-store-alias
SAPO_GO_USERNAME=your_username@email.com
SAPO_GO_PASSWORD=your_password

# Số sản phẩm lấy từ Sapo Marketplace để đồng bộ tab Sản phẩm (tối đa 200)
SAPO_PRODUCT_REPORT_LIMIT=50

# Danh sách shop loại trừ khỏi báo cáo (phân cách bởi dấu phẩy, để trống = lấy tất cả)
EXCLUDED_SHOPS=

# ==========================================
# SAPO API CONFIG (INTEGRATION_MODE=sapo_api)
# ==========================================
SAPO_STORE=
SAPO_ACCESS_TOKEN=
SAPO_API_KEY=
SAPO_API_SECRET=
SAPO_WEBHOOK_VERIFY_TOKEN=

# ==========================================
# LARK (FEISHU) CREDENTIALS
# ==========================================
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID của nhóm nhận báo cáo (lấy bằng API /api/lark/chats)
LARK_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# LARK BASE (BITABLE) — Báo cáo hàng ngày
# ==========================================
# App Token của file Bitable chứa bảng BÁO CÁO HÀNG NGÀY
LARK_BASE_APP_TOKEN=JJ4cbywbXalFOOsK4iCj2bvNpAd

# Số sản phẩm hiển thị trong Lark Message Card (Lark Base luôn ghi đầy đủ)
LARK_PRODUCT_CARD_LIMIT=15

# ==========================================
# SERVER CONFIG
# ==========================================
PORT=3000
NODE_ENV=production

# ==========================================
# SCHEDULE CONFIG (cron syntax)
# ==========================================
# Báo cáo tự động lúc 7:00 sáng hàng ngày (múi giờ Asia/Ho_Chi_Minh)
REPORT_CRON=0 7 * * *

# ==========================================
# TIMEZONE
# ==========================================
TZ=Asia/Ho_Chi_Minh
